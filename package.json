{
  "name": "downmusic",
  "version": "0.1.0",
  "description": "App desktop para resolver e baixar musica de multiplas fontes (Spotify -> YouTube, YouTube, Bandcamp, SoundCloud).",
  "main": "out/main/index.js",
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.downmusic.app",
    "productName": "DownMusic",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "npmRebuild": false,
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo"
    }
  },
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "start": "electron-vite preview -- --no-sandbox",
    "dist": "electron-vite build && electron-builder --linux AppImage",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "execa": "^8.0.1",
    "p-queue": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "playwright-core": "^1.61.1",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.3.0",
    "vitest": "^1.3.0"
  }
}
